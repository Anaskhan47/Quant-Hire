{
  "version": 2,
  "name": "quanthire",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.py" },
    { "source": "/css/(.*)", "destination": "/css/$1" },
    { "source": "/js/(.*)", "destination": "/js/$1" },
    { "source": "/pipeline/artifacts/(.*)", "destination": "/pipeline/artifacts/$1" },
    { "source": "/logo.svg", "destination": "/logo.svg" },
    { "source": "/((?!api|css|js|pipeline|logo.svg).*)", "destination": "/index.html" }
  ]
}
