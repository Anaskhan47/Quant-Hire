{
  "version": 2,
  "name": "quanthire",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/pipeline/artifacts/(.*)", "dest": "/pipeline/artifacts/$1" },
    { "src": "/logo.svg", "dest": "/logo.svg" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
